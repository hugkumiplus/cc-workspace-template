{
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r -f *)",
      "Bash(rm -r *)",
      "Bash(dd if=*)",
      "Bash(mkfs*)",
      "Bash(chmod 777*)",
      "Bash(chmod -R 777*)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git add .)",
      "Bash(git add -A)",
      "Bash(aws *)",
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(kubectl delete*)",
      "Bash(docker rm -f*)",
      "Bash(npm publish*)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(eval *)",
      "Bash(exec *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(credentials.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.kube/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.git-credentials)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(credentials.*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.bash_profile)",
      "Edit(~/.zprofile)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(credentials.*)",
      "Write(**/*.pem)",
      "Write(**/*.key)"
    ],
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git commit*)",
      "Bash(git push origin*)",
      "Bash(ls*)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(date*)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(* --version)",
      "Bash(* --help)",
      "WebSearch",
      "WebFetch"
    ]
  },
  "sandbox": {
    "enabled": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/scripts/block-dangerous-commands.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/scripts/block-main-push.sh"
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/scripts/protect-sensitive-files.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/scripts/protect-data.sh"
          }
        ]
      }
    ]
  }
}
